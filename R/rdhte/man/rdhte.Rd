                   cluster = cluster_var)
  summary(rd_left)
  rdhte_lincom(rd_left,
               linfct = "`factor(w_left)1` - `factor(w_left)0` = 0")

  summary(rdhte(y = y, x = x, covs.hte = factor(w_left),
                cluster = cluster_var, bw.joint = TRUE))
  summary(rdhte(y = y, x = x, covs.hte = factor(w_left):factor(w_strong),
                cluster = cluster_var))
